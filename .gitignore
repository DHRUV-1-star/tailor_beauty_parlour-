# ============================================
# .gitignore - Shringar Project
# ============================================

# Node.js dependencies (NEVER commit these)
node_modules/
backend/node_modules/

# Environment files (contains passwords/secrets)
.env
backend/.env

# Logs
*.log
npm-debug.log*
logs/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/settings.json
*.suo
*.user

# Build output
dist/
build/

# Temp files
*.tmp
*.temp
