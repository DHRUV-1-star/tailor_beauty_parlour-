# ============================================
# Shringar Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017/shringar_db

# Option 2: MongoDB Atlas (Cloud - Recommended)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shringar_db?retryWrites=true&w=majority

# JWT Secret (change this to a long random string)
JWT_SECRET=shringar_super_secret_key_change_this_in_production_2024

# Email Configuration (for appointment confirmation emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Business Info
BUSINESS_NAME=Shringar Tailoring and Beauty Parlour
BUSINESS_PHONE=+919999999999
BUSINESS_EMAIL=shringar.parlour@gmail.com
